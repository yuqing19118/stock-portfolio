# BuffetBot — environment variables
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Notifications (pick one or both) ──────────────────────────────

# Telegram (recommended — instant, free)
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message @userinfobot to get your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio SMS (optional)
# Rotate any credential that was pasted into chat before using it here.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Or use API key auth instead of auth token:
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15557654321

# Email (Gmail) — optional fallback
# Enable "App Passwords" in your Google account first
ALERT_EMAIL_FROM=youremail@gmail.com
ALERT_EMAIL_TO=youremail@gmail.com
SMTP_PASSWORD=

# ── Portfolio settings ────────────────────────────────────────────
PAPER_CAPITAL=50000
MAX_POSITION_PCT=15
STOP_LOSS_PCT=7
TAKE_PROFIT_PCT=25
BENCHMARK_SYMBOL=SPY
DAILY_PUBLISH_DASHBOARD=false
DIGEST_EVERY_HOURS=3
DASHBOARD_URL=https://yuqing19118.github.io/stock-portfolio/

# ── Timezone ──────────────────────────────────────────────────────
# The bundled schedule below is set for U.S. market hours in Los Angeles local time.
TZ=America/Los_Angeles
