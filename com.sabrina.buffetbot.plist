<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sabrina.buffetbot</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/sabrina/Downloads/buffet-agent/agent.py</string>
